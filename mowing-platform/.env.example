# GardenOS Mowing Platform 环境配置
# 复制此文件为 .env 并填入实际值

# ── PostgreSQL 连接 ──────────────────────────────────────
PGHOST=127.0.0.1
PGPORT=5433
PGDATABASE=MyGardenOSManagementSyetem
PGUSER=happyfamily
PGPASSWORD=
# 或者直接使用 DATABASE_URL（优先于上述分项配置）
DATABASE_URL=postgresql://happyfamily@127.0.0.1:5433/MyGardenOSManagementSyetem

# ── Clerk 认证 ───────────────────────────────────────────
# ClerK_Public_Key=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 管理员 / 服务商邮箱（逗号分隔） ───────────────────────
# ADMIN_EMAILS=admin@example.com
# PROVIDER_EMAILS=provider@example.com

# ── SMTP 邮件服务（可选，开发模式下验证码打印在控制台） ──
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASS=your_password
