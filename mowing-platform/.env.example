# Development PostgreSQL configuration
# Keep real passwords out of tracked files.

PGHOST=127.0.0.1
PGPORT=5433
PGDATABASE=MyGardenOSManagementSyetem
PGUSER=your_local_postgres_user
# Leave blank when local PostgreSQL uses trust authentication.
PGPASSWORD=

# If the app stack prefers one connection string, build it from the values above.
DATABASE_URL=postgresql://your_local_postgres_user@127.0.0.1:5433/MyGardenOSManagementSyetem

# Address lookup provider
GEOAPIFY_API_KEY=your_geoapify_api_key

# Geoapify geocoding API key — required for address autocomplete and reverse geocode.
# Sign up at https://www.geoapify.com/ to get a free key.
GEOAPIFY_API_KEY=your_geoapify_api_key_here
