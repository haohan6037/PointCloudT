{"expo":{"name":"MyGardenOS","slug":"mygardenos","version":"0.1.0","orientation":"portrait","ios":{"supportsTablet":true,"bundleIdentifier":"com.mygardenos.dev","infoPlist":{"NSLocationWhenInUseUsageDescription":"This app uses your location to provide nearby address suggestions when editing your profile.","NSPhotoLibraryUsageDescription":"Allow MyGardenOS to access your photos to set a profile picture.","NSCameraUsageDescription":"Allow MyGardenOS to use the camera to take a profile picture."}},"android":{"permissions":["ACCESS_COARSE_LOCATION","ACCESS_FINE_LOCATION","CAMERA","READ_EXTERNAL_STORAGE"]},"plugins":[["expo-location",{"locationWhenInUsePermission":"Allow MyGardenOS to use your location to suggest nearby addresses."}],["expo-image-picker",{"photosPermission":"Allow MyGardenOS to access your photos to set a profile picture.","cameraPermission":"Allow MyGardenOS to use the camera to take a profile picture."}]],"extra":{"apiUrl":"http://localhost:8000"}}}
